# ─────────────────────────────────────────────
#  IGNIS BOT — Environment Variables Template
#  Copy this file to .env and fill in the values
#  NEVER commit your real .env to git!
# ─────────────────────────────────────────────

# REQUIRED — Your bot's Discord token (from Discord Developer Portal)
DISCORD_TOKEN=

# REQUIRED — Your bot's Application ID (from Discord Developer Portal)
APPLICATION_ID=

# OPTIONAL — Top.gg API token for voting integration
TOPGG_TOKEN=

# OPTIONAL — Webhook URL for command logging
COMMAND_LOG_WEBHOOK=

# OPTIONAL — Channel ID for "Bot joined server" log
GUILD_JOIN_LOG_CHANNEL_ID=

# OPTIONAL — Voice channel IDs for live server/user stats
STATS_SERVERS_CHANNEL_ID=
STATS_USERS_CHANNEL_ID=

# OPTIONAL — MongoDB connection string for persistent data
MONGO_URI=

# OPTIONAL — AI / Groq API key (for AI features)
GROQ_API_KEY=

# OPTIONAL — OpenAI API key (if using OpenAI instead of Groq)
OPENAI_API_KEY=
